RewriteEngine On

ErrorDocument 404 /404

# Don't rewrite requests that already target /public/
RewriteCond %{REQUEST_URI} !^/public/

# If a .php file exists in public/ for this path, serve it (clean URLs)
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI}.php -f
RewriteRule ^(.*)$ public/$1.php [L,QSA]

# Otherwise route transparently into public/ (directories, index.php, assets)
RewriteCond %{REQUEST_URI} !^/public/
RewriteRule ^(.*)$ public/$1 [L,QSA]
